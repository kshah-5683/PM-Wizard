# API Keys (Provide your own values)
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pm_wizard

# Model Routing Configuration
PRIMARY_MODEL=groq/llama-3.3-70b-versatile
LIGHTWEIGHT_MODEL=groq/llama-3.1-8b-instant
CRITIC_MODEL=groq/llama-3.1-8b-instant

# RAG & Embedding Configuration
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536

# JIT Codebase Inspector Configuration
PROJECT_ROOT=

# LLM Fallbacks & Limits
FALLBACK_PRIMARY_MODEL=github/meta-llama-3.3-70b-instruct
FALLBACK_CRITIC_MODEL=github/meta-llama-3.1-8b-instruct
MODEL_MAX_TOKENS=128000

# Development Caching (set to true to enable disk cache)
LLM_CACHE_ENABLED=false

# LangSmith Tracing (set to true to enable observability)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
